{
  "name": "@rtl-text-fixer/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "test": "pnpm vitest run",
    "test:watch": "pnpm vitest",
    "lint": "eslint src vitest.config.ts --max-warnings=0"
  },
  "dependencies": {
    "@rtl-text-fixer/shared": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
